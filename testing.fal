ffimport "testing-wrapper.cpp" ("-I/opt/falcon/include/") ("-L/opt/falcon/lib/")

// ── TestContext ────────────────────────────────────────────────────────────
// One per test.  Write assertions against it; the runner reads pass/fail.
struct TestContext {
    routine New           (string name)                                              -> (TestContext ctx)
    routine Name                                                                     -> (string name)
    routine Passed                                                                   -> (bool passed)
    routine FailureCount                                                             -> (int count)
    routine ExpectTrue    (bool condition,  string msg)                              -> (Error err)
    routine ExpectFalse   (bool condition,  string msg)                              -> (Error err)
    routine ExpectIntEq   (int  expected,   int    actual,  string msg)              -> (Error err)
    routine ExpectIntNe   (int  expected,   int    actual,  string msg)              -> (Error err)
    routine ExpectIntLt   (int  a,          int    b,       string msg)              -> (Error err)
    routine ExpectIntGt   (int  a,          int    b,       string msg)              -> (Error err)
    routine ExpectFloatEq (float expected,  float  actual,  float tol, string msg)  -> (Error err)
    routine ExpectStrEq   (string expected, string actual,  string msg)              -> (Error err)
    routine ExpectStrNe   (string expected, string actual,  string msg)              -> (Error err)
    routine Fail          (string msg)                                               -> (Error err)
    routine Log           (string msg)                                               -> (Error err)
}

// ── TestRunner ─────────────────────────────────────────────────────────────
// Owns the loop state, index, and all terminal output.
// Created and managed entirely by the generated harness — not by user code.
struct TestRunner {
    routine New           (string suite_name) -> (TestRunner runner)
    routine Register      (string test_name)  -> (Error err)
    routine PrintHeader                       -> (Error err)
    routine BeginCurrent                      -> (TestContext ctx)
    routine EndCurrent    (TestContext ctx)    -> (Error err)
    routine HasNext                           -> (bool has_next)
    routine CurrentName                       -> (string name)
    routine PrintSummary                      -> (Error err)
    routine PassedCount                       -> (int count)
    routine FailedCount                       -> (int count)
}
